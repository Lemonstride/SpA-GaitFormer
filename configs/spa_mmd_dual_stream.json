{
  "data": {
    "dataset_root": "../datasets/SpA-MMD/processed",
    "train_split": "../splits/train_subjects.txt",
    "val_split": null,
    "test_split": "../splits/test_subjects.txt",
    "session": "walk",
    "rgb_dir": "rgb",
    "skeleton_file": "skeleton/kpt3d/kpt3d.npy",
    "binary_label_file": "labels/binary_label.txt",
    "severity_label_file": "labels/severity_label.txt",
    "strict_missing_files": true,
    "num_frames": 24,
    "image_size": 224,
    "rgb_mean": [0.485, 0.456, 0.406],
    "rgb_std": [0.229, 0.224, 0.225],
    "max_joints": 25,
    "joint_dim": 3,
    "normalize_skeleton": true
  },
  "model": {
    "input_mode": "fusion",
    "embed_dim": 256,
    "rgb_patch_size": 16,
    "rgb_spatial_depth": 2,
    "rgb_temporal_depth": 2,
    "skeleton_joint_depth": 2,
    "skeleton_temporal_depth": 2,
    "fusion_depth": 4,
    "num_heads": 8,
    "mlp_ratio": 4.0,
    "dropout": 0.1
  },
  "task": {
    "severity_mode": "classification",
    "severity_num_classes": 4,
    "disease_loss_weight": 1.0,
    "severity_loss_weight": 1.0,
    "disease_pos_weight": null
  },
  "train": {
    "batch_size": 4,
    "epochs": 50,
    "learning_rate": 0.0003,
    "weight_decay": 0.0001,
    "num_workers": 4,
    "device": "cuda",
    "checkpoint_dir": "../checkpoints/spa_mmd_dual_stream",
    "log_interval": 10,
    "amp": true,
    "seed": 42
  },
  "cv": {
    "enabled": true,
    "num_folds": 2,
    "seed": 42,
    "selection_metric": "loss",
    "use_mean_best_epoch": true,
    "final_epochs": null
  }
}
